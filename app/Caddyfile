{$DOMAIN} {
	tls {
		dns duckdns {$DUCKDNS_API_TOKEN}
	}

	handle /api/* {
		reverse_proxy backend:8000
	}

	handle /ws/* {
		reverse_proxy backend:8000
	}

	handle /health {
		reverse_proxy backend:8000
	}

	handle {
		reverse_proxy frontend:3000
	}
}

{$LIVEKIT_DOMAIN} {
	tls {
		dns duckdns {$DUCKDNS_API_TOKEN}
	}

	reverse_proxy host.docker.internal:7880
}
