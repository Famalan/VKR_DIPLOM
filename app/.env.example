# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/interview_platform
POSTGRES_DB=interview_platform
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
JWT_SECRET=change-me-in-production
CORS_ORIGINS=http://localhost:3000

# API Credentials (required)
SALUTE_SPEECH_CREDENTIALS=your-salute-speech-credentials
GIGACHAT_CREDENTIALS=your-gigachat-credentials

# Redis
REDIS_URL=redis://localhost:6379/0

# LiveKit
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_URL=ws://localhost:7880

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880
